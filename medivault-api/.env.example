# ==============================================
# MediVault API - Railway Deployment Variables
# ==============================================

# ----------------------------
# Database (Railway PostgreSQL plugin aap-aap aape che)
# Railway ma "PostgreSQL" service add karo, pachi
# aa variable Reference thi link karo: ${{Postgres.DATABASE_URL}}
# Khali rakho to local SQLite vapraay (dev mate)
# ----------------------------
DATABASE_URL=

# ----------------------------
# JWT Secret (production ma majboot random string nakho)
# Generate: openssl rand -hex 32
# ----------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----------------------------
# OTP Mode
# dev  = OTP fixed "123456" ane response ma return thaay (SMS gateway vagar)
# prod = real SMS gateway joie (have implement karelu nathi)
# ----------------------------
OTP_MODE=dev
OTP_DEV_CODE=123456

# ----------------------------
# CORS - Frontend nu URL (comma-separated)
# dા.ત. https://medivault-web-production.up.railway.app
# ----------------------------
CORS_ORIGINS=*

# ----------------------------
# App
# ----------------------------
ENVIRONMENT=production
