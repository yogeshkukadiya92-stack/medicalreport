# ==============================================
# MediVault API - Railway Deployment Variables
# ==============================================

# ----------------------------
# Database (Railway PostgreSQL plugin aap-aap aape che)
# Railway ma "PostgreSQL" service add karo, pachi
# aa variable Reference thi link karo: ${{Postgres.DATABASE_URL}}
# ----------------------------
DATABASE_URL=

# ----------------------------
# Supabase JWT Secret  ← IMPORTANT for production
# Supabase Dashboard → Project Settings → API → JWT Secret
# Aa set thay etle Supabase tokens verify thay — custom OTP ni jarur nathi.
# ----------------------------
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ----------------------------
# Our own JWT (fallback for local dev without Supabase)
# Generate: openssl rand -hex 32
# ----------------------------
JWT_SECRET_KEY=change-me-to-a-long-random-secret-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----------------------------
# OTP Dev Mode (only used when SUPABASE_JWT_SECRET is empty)
# dev  = OTP fixed "123456" ane response ma return thaay
# ----------------------------
OTP_MODE=dev
OTP_DEV_CODE=123456

# ----------------------------
# CORS - Frontend URL (comma-separated)
# dા.ત. https://medivault-web-production.up.railway.app
# ----------------------------
CORS_ORIGINS=*

# ----------------------------
# App
# ----------------------------
ENVIRONMENT=production
