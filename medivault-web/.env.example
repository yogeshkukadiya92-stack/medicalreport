# ==============================================
# MediVault Web — Railway Deployment Variables
# ==============================================
# Railway Dashboard ma aa variables set karo:
# Project > Variables section ma

# ----------------------------
# Supabase (https://supabase.com → Project Settings → API)
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ----------------------------
# Backend API URL
# Railway ma backend service deploy thay etle a URL malse
# dા.ત. https://medivault-api-production.up.railway.app/v1
# ----------------------------
NEXT_PUBLIC_API_URL=https://your-backend-service.railway.app/v1

# ----------------------------
# App
# ----------------------------
NEXT_PUBLIC_APP_NAME=MediVault
NODE_ENV=production

# ----------------------------
# Port (Railway automatic set kare, manually jari nathi)
# ----------------------------
PORT=3000
