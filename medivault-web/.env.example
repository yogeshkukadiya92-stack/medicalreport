# ==============================================
# MediVault - Railway Deployment Variables
# ==============================================
# Railway Dashboard ma aa variables set karo:
# Project > Variables section ma

# ----------------------------
# App Configuration
# ----------------------------
NEXT_PUBLIC_APP_NAME=MediVault
NODE_ENV=production

# ----------------------------
# Backend API URL
# (Railway backend service URL)
# ----------------------------
NEXT_PUBLIC_API_URL=https://your-backend-service.railway.app/v1

# ----------------------------
# Port (Railway automatic set kare che)
# manually set karvi jari nathi
# ----------------------------
PORT=3000
