NEXT_PUBLIC_APP_NAME=MediVault

# Required for MongoDB-only auth, cloud vault, lab dashboard, original file storage, and report sync.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=medivault

# Optional. Used for lab "today" counters and date filters.
APP_TIME_ZONE=Asia/Kolkata

# Optional. Enables "Pay online" on public lab booking pages.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_CURRENCY=INR

# Optional AI provider for client self-upload analysis. Lab-created reports do not use AI.
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
NVIDIA_API_KEY=nvapi-your-nvidia-api-key
NVIDIA_MODEL=meta/llama-3.2-11b-vision-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com
